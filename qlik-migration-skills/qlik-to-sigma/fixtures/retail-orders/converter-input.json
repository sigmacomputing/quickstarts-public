    {
      "title": "Holiday Revenue",
      "qDef": "Sum({<IS_HOLIDAY={1}>} NET_REVENUE)"
    },
    {
      "title": "Net Margin %",
      "qDef": "Sum(NET_PROFIT)/Sum(NET_REVENUE)"
    },
