    {
      "title": "Avg Days to Ship",
      "qDef": "Avg(DAYS_TO_SHIP)"
    },
    {
      "title": "Avg Order Value",
      "qDef": "Sum(NET_REVENUE)/Count(DISTINCT ORDER_ID)"
    },
