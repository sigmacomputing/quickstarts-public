# Embed Series 2 - GIT COPY

##############################################################################
# Environment Configuration Notes:
#
# - CLIENT_ID, SECRET, SESSION_LENGTH, and PORT are shared settings.
# - Default Embed User (EMAIL, ACCOUNT_TYPE, TEAMS) is **MANDATORY**.
#   - Always used unless overridden per QuickStart.
# - QS-specific settings can override any of the defaults.
#   - QS mode name → uppercased with underscores (_).
###############################################################################

###############################################################
# Shared by all QuickStarts (except public embed)
###############################################################

SESSION_LENGTH=3600
PORT=3000

CLIENT_ID=
SECRET=

# OPTIONAL EMBED PARAMETERS (defaults are shown)
disable_auto_refresh=false
disable_mobile_view=false
hide_folder_navigation=false
hide_menu=false
hide_page_controls=false
hide_reload_button=false
hide_title=false
hide_tooltip=false
hide_view_select=false
lng=English
menu_position=top
page_id=
responsive_height=false
theme=Lite
view_id=

#########################################################
# Default Embed User (used if none specified) - MANDATORY
#########################################################

EMAIL=sales_person@example.com
ACCOUNT_TYPE=View
TEAMS=Sales_People

